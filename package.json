{
  "name": "living-agent",
  "version": "0.1.0",
  "description": "AI agent with an internal ecology of strategies that compete and evolve based on real task performance",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./integrations/openclaw": {
      "types": "./dist/integrations/openclaw/plugin.d.ts",
      "import": "./dist/integrations/openclaw/plugin.js"
    }
  },
  "bin": {
    "living-agent": "dist/cli/tui.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsx benchmarks/run.ts",
    "bench:verbose": "tsx benchmarks/run.ts --verbose",
    "bench:detailed": "BENCH_JSON=1 tsx benchmarks/run.ts --verbose",
    "bench:real": "tsx benchmarks/run.ts --real --verbose"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "evolution",
    "genetic-algorithm",
    "map-elites",
    "novelty-search",
    "prompt-optimization",
    "anthropic",
    "claude",
    "strategy",
    "adaptive"
  ],
  "license": "BSL-1.1",
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/Kanano/living-agent.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "ink": "^5.2.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1"
  },
  "peerDependencies": {
    "langfuse": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "langfuse": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^18.3.28",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
